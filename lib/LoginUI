#include <iostream>
#include <string>
#include <map>

using namespace std;

class LoginUI {
private:
    map<string, string> maps; //dict
    string idinput;
    string passwordInput;

public:
    LoginUI() {
        // dict
        maps["s001"] = "pass123";
        maps["s002"] = "hello99";
        maps["a001"] = "admin@1";
        idinput = "";
        passwordInput = "";
    }
    //setters
    void setId(string id) { idinput = id; }
    void setPass(string pass) { passwordInput = pass; }

    void launchauthenticatedsession() {
        if (maps.count(idinput) > 0) {
            if (maps[idinput] == passwordInput) {
                if (idinput[0] == 'a') {
                    cout << "success: admin ui active." << endl;
                } else {
                    cout << "success: Student ui active." << endl;
                }
            } else {
                cout << "error: " << passwordInput << " is incorrect for id " << idinput << "." << endl;
            }
        } else {
            cout << "error: " << idinput << " not found." << endl;
        }
    }
};
